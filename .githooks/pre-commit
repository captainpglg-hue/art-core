#!/usr/bin/env sh
# Refuse to commit text files containing NUL bytes (corruption from buggy editors on CRLF).
# Install once per clone: git config core.hooksPath .githooks
python - <<'PYEOF'
import subprocess, sys
res = subprocess.run(['git','diff','--cached','--name-only','--diff-filter=ACMR'],
                    capture_output=True, text=True)
files = [f for f in res.stdout.split('\n') if f.strip()]
text_ext = {'.ts','.tsx','.js','.jsx','.mjs','.cjs','.json','.md','.css','.scss',
            '.html','.svg','.yml','.yaml','.sh','.sql','.txt','.env','.gitignore',
            '.gitattributes'}
bad = []
for f in files:
    if not any(f.endswith(e) for e in text_ext) and '.' in f.split('/')[-1]:
        continue
    try:
        with open(f, 'rb') as fh:
            if b'\x00' in fh.read():
                bad.append(f)
    except FileNotFoundError:
        pass
if bad:
    sys.stderr.write('\n[pre-commit] NUL bytes detected (would break builds):\n')
    for f in bad:
        sys.stderr.write('  - ' + f + '\n')
    sys.stderr.write('\nFix: rewrite the file via Read+Write (not Edit), then re-stage.\n\n')
    sys.exit(1)
PYEOF
