# prime-core — variables d'environnement (exemple)

# Base Supabase partagée avec art-core / pass-core
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://prime-core.app

# --- SSO inter-domaines (art-core = fournisseur d'identité) ---
# Base URL de l'IdP art-core (dev : http://localhost:3000)
NEXT_PUBLIC_ART_CORE_URL=https://art-core.app
# Secret partagé serveur-à-serveur — DOIT être identique sur art-core, pass-core
# et prime-core. Générer avec : openssl rand -hex 32
SSO_SHARED_SECRET=
