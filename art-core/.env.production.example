# ============================================================
# ART-CORE — Production Environment Variables
# Copy this file to .env.production.local and fill in values.
# Add ALL these variables in Vercel: Settings → Environment Variables
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Found at: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── PostgreSQL Direct Connection ──────────────────────────────
# Found at: Supabase Dashboard → Settings → Database → Connection string → URI
# Use Transaction Pooler (port 6543) for Vercel (serverless)
DATABASE_URL=

# ── Stripe ────────────────────────────────────────────────────
# Found at: dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Found at: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Your platform Stripe account ID (acct_xxxx)
STRIPE_PLATFORM_ACCOUNT_ID=

# ── Cloudinary ────────────────────────────────────────────────
# Found at: cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Upload presets created in Cloudinary Settings → Upload → Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_ARTWORKS=art_core_artworks
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_AVATARS=art_core_avatars

# ── App URLs ──────────────────────────────────────────────────
# Your production Vercel domain (without trailing slash)
NEXT_PUBLIC_APP_URL=https://art-core.app
NEXT_PUBLIC_PASS_CORE_URL=https://pass-core.app
NEXT_PUBLIC_ART_CORE_URL=https://art-core.app
NEXT_PUBLIC_PRIME_CORE_URL=https://prime-core.app

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://art-core.app

# Google OAuth (optional) — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────────────
# Found at: resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@art-core.app

# ── Blockchain (Polygon) ──────────────────────────────────────
# Set to 'simulation' until contract is deployed
BLOCKCHAIN_NETWORK=polygon
BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_CHAIN_ID=137
PASS_CORE_CONTRACT_ADDRESS=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_EXPLORER_URL=https://polygonscan.com

# ── Feature Flags ─────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_BLOCKCHAIN=false
NEXT_PUBLIC_ENABLE_AUCTIONS=true
NEXT_PUBLIC_ENABLE_RENTALS=true
NEXT_PUBLIC_ENABLE_SCOUTING=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ── Certification settings ────────────────────────────────────
MIN_CERTIFICATION_QUALITY=60
MAX_CERTIFICATION_FILE_SIZE=52428800
