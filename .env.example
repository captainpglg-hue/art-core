# ============================================================
# ART-CORE — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Stripe Connect ────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe account ID of the platform (Art-core LTD)
STRIPE_PLATFORM_ACCOUNT_ID=acct_...

# ── Cloudinary ────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Upload presets (create in Cloudinary dashboard)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_ARTWORKS=art_core_artworks
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_AVATARS=art_core_avatars

# ── Blockchain / Pass-Core ────────────────────────────────────
# Network: "polygon" | "base" | "ethereum" | "simulation"
BLOCKCHAIN_NETWORK=simulation
BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_CHAIN_ID=137
PASS_CORE_CONTRACT_ADDRESS=0x...
BLOCKCHAIN_PRIVATE_KEY=0x...
BLOCKCHAIN_EXPLORER_URL=https://polygonscan.com

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PASS_CORE_URL=http://localhost:3000/pass-core
NEXT_PUBLIC_ART_CORE_URL=http://localhost:3000/art-core
NEXT_PUBLIC_PRIME_CORE_URL=http://localhost:3000/prime-core

# ── Auth / SSO ────────────────────────────────────────────────
# Shared auth secret across all 3 apps
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend / SendGrid) ─────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@art-core.com

# ── Platform Config ───────────────────────────────────────────
# Commission rates (decimal, e.g. 0.10 = 10%)
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=10
PLATFORM_COMMISSION_RATE=0.10
ARTIST_ROYALTY_RATE=0.05
SCOUT_COMMISSION_RATE=0.02

# ── Feature Flags ─────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_BLOCKCHAIN=false
NEXT_PUBLIC_ENABLE_AUCTIONS=true
NEXT_PUBLIC_ENABLE_RENTALS=true
NEXT_PUBLIC_ENABLE_SCOUTING=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
