# ============================================================
# PASS-CORE — Variables d'environnement PRODUCTION
# Ces valeurs doivent être configurées dans Vercel Dashboard
# ou via : vercel env add VARIABLE_NAME production
# ============================================================

# ── Supabase (partagé avec art-core) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://kmmlwuwsahtzgzztcdaj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (partagé avec art-core) ───────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Cloudinary (partagé avec art-core) ───────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Anthropic (IA description) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Blockchain ───────────────────────────────────────────────
BLOCKCHAIN_NETWORK=simulation
BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_CHAIN_ID=137
PASS_CORE_CONTRACT_ADDRESS=0x...
BLOCKCHAIN_PRIVATE_KEY=0x...
BLOCKCHAIN_EXPLORER_URL=https://polygonscan.com

# ── URLs de production (CRITIQUE — pas de localhost !) ───────
NEXT_PUBLIC_APP_URL=https://pass-core.app
NEXT_PUBLIC_PASS_CORE_URL=https://pass-core.app
NEXT_PUBLIC_ART_CORE_URL=https://art-core.app
NEXT_PUBLIC_PRIME_CORE_URL=https://prime-core.app
